    "html": "<html lang=\"fa\" dir=\"rtl\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>وب‌سرویس(API) قیمت دلار، طلا، سکه و سایر | الان چند</title>\n        <link rel=\"canonical\" href=\"https://alanchand.com/media/api\">\n    <link rel=\"alternate\" hreflang=\"fa\" href=\"https://alanchand.com/media/api\">\n    <link rel=\"alternate\" hreflang=\"en\" href=\"https://alanchand.com/en/media/api\">\n    <link rel=\"alternate\" hreflang=\"tr\" href=\"https://alanchand.com/tr/media/api\">\n    <link rel=\"alternate\" hreflang=\"x-default\" href=\"https://alanchand.com/media/api\">\n    \n    <meta name=\"description\" content=\"وب‌سرویس «الان چند» امکان دریافت قیمت لحظه‌ای ارز، طلا و ارز دیجیتال را به صورت JSON فراهم می‌کند. این سرویس به صورت تستی در دسترس است و هر کاربر می‌تواند یک بار در ساعت از آن استفاده کند. برای دسترسی نامحدود، لطفاً از طریق صفحه تماس با ما اقدام نمایید.\">\n    <link rel=\"stylesheet\" href=\"/assets/css/styles.css\">\n            <link rel=\"stylesheet\" href=\"/assets/css/mediastyles.css\">\n        <link rel=\"stylesheet\" href=\"/assets/css/flag.css\">\n    <link rel=\"icon\" href=\"/assets/img/logo/SmallTile.scale-100.png\" type=\"image/png\">\n    <link rel=\"manifest\" href=\"/manifest.json\">\n    <meta name=\"theme-color\" content=\"#183FC1\">\n    <script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"هزینه استفاده از API چقدر است؟\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"دو پلن برای استفاده از API وجود دارد: پلن ۶ ماهه با هزینه ۶۵ تتر و پلن یک‌ساله با هزینه ۱۰۰ تتر.\"}},{\"@type\":\"Question\",\"name\":\"آیا امکان تست API وجود دارد؟\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"بله، از طریق ربات تلگرامی که لینک آن در همین صفحه قرار دارد می‌توانید به‌صورت خودکار یک توکن رایگان ۳ روزه برای تست دریافت کنید.\"}},{\"@type\":\"Question\",\"name\":\"آیا استفاده از API محدودیت دارد؟\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"بله، حداکثر ۱۵۰۰ درخواست در روز و ۵۰۰۰۰ درخواست در ماه مجاز است.\"}},{\"@type\":\"Question\",\"name\":\"آیا امکان استفاده از WebSocket وجود دارد؟\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"متأسفانه خیر، در حال حاضر تنها دسترسی از طریق API REST فراهم است.\"}},{\"@type\":\"Question\",\"name\":\"اگر از API راضی نبودیم آیا امکان بازگشت وجه وجود دارد؟\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"در صورتی که مشکل از سمت ما باشد (مانند کندی، اختلال، یا به‌روزرسانی‌نشدن قیمت‌ها)، بازگشت وجه در هر زمان امکان‌پذیر است. در غیر این صورت، تنها تا ۷ روز پس از خرید می‌توانید از طریق پشتیبانی درخواست بازگشت وجه ثبت کنید.\"}}]}</script>\n</head>\n\n<body class=\"MainLanding\">\n    <header class=\"alanHeader position-relative\">\n        <div class=\"HeaderInner\">\n            <div class=\"container deskMenuTop\">\n                <div class=\"d-flex align-items-center\">\n                    <a href=\"/\" class=\"acNavLogo me-3\">\n                        <img src=\"/assets/img/logo/alanchandLogo.svg\" alt=\"الان چند؟! نرخ لحظه ای ارز، طلا، سکه و کریپتو\">\n                    </a>\n                    <nav class=\"navMenu\">\n                        <a href=\"/currencies-price\" class=\"currMenu\">ارزها</a>\n                        <a href=\"/crypto-price\" class=\"CryptoMenu\">ارز دیجیتال</a>\n                        <a href=\"/gold-price\" class=\"goldMenu\">طلا و سکه</a>\n                        <a href=\"/exchange-rates/eur-usd\" class=\"ConvertMenu\">تبدیل ارز</a>\n                        <a href=\"/media\" class=\"mediaMenu\">رسانه‌های ما</a>\n                        <div class=\"dot\"></div>\n                    </nav>\n                </div>\n                <div class=\"d-flex align-items-center\">\n                    <div class=\"acDropList me-2 position-relative\">\n                        <span class=\"d-flex align-items-center\">\n                            فارسی<i class=\"flag flag-ir\"></i>                        </span>\n                        <div class=\"selectLang p-3\" style=\"display: none;\">\n                                                                                                                                                            <span class=\"d-flex align-items-center\">\n                                        <a href=\"/en/media/api\">English</a>\n                                        <i class=\"flag flag-us\"></i>\n                                    </span>\n                                                                                                                                <span class=\"d-flex align-items-center\">\n                                        <a href=\"/tr/media/api\">Türkçe</a>\n                                        <i class=\"flag flag-tr\"></i>\n                                    </span>\n                                                                                    </div>\n                    </div>\n                </div>\n            </div>\n\n        </div>\n    </header>\n    <main>\n\n  <section class=\"container mt-5\">\n    <div class=\"text-center\"><img src=\"/assets/img/media/apiImg.jpg\" alt=\"وب سرویس الان چند\"></div>\n    <h1 class=\"fs-4 text-center mt-5\">وب سرویس دریافت قیمت، الان چند؟</h1>\n    <p class=\"text-center\">\n      وب‌سرویس «الان چند» امکان دریافت قیمت لحظه‌ای ارز، طلا و ارز دیجیتال را به صورت JSON فراهم می‌کند. این سرویس به صورت تستی در دسترس است و هر کاربر می‌تواند یک بار در ساعت از آن استفاده کند. برای دسترسی نامحدود، لطفاً از طریق صفحه تماس با ما اقدام نمایید.\n    </p>\n\n    <p class=\"text-center\"><a href=\"https://t.me/alanchand_token_bot\" target=\"_blank\" class=\"btn btnApi text-white\">درخواست رایگان API</a></p>\n  </section>\n\n  <div class=\"codeContainer\">\n    <h2 class=\"fs-5 mb-3\">پارامترهای ورودی</h2>\n    <div class=\"table-responsive\">\n      <table class=\"table text-white bg-dark\">\n        <thead>\n          <tr><th>پارامتر</th><th>نوع</th><th>توضیح</th></tr>\n        </thead>\n        <tbody> \n          <tr>\n            <td><code>type</code></td>\n            <td>string</td>\n            <td>دسته‌ی مورد نظر: <code>currency</code> (ارز)، <code>gold</code> (طلا)، <code>crypto</code> (رمزارز)</td>\n          </tr>\n          <tr>\n            <td><code>symbols</code></td>\n            <td>comma-separated list</td>\n            <td>نمادهایی که از همان دسته انتخاب شده‌اند. مانند: <code>usd,eur</code> یا <code>btc,eth</code></td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n    <p class=\"text-white\">تمام درخواست‌ها باید در هدر شامل توکن معتبر باشند:</p>\n    <div class=\"code-box\">\n      <button class=\"copy-btn\" onclick=\"copyCode(this)\">کپی</button>\n      <pre>Authorization: Bearer YOUR_API_TOKEN</pre>\n    </div>\n    <p class=\"text-white mt-4\">فرمت درخواست:</p>\n    <div class=\"code-box\">\n      <button class=\"copy-btn\" onclick=\"copyCode(this)\">کپی</button>\n      <pre>GET https://api.alanchand.com?type=crypto&amp;symbols=btc,eth</pre>\n    </div>\n  </div>\n  <div class=\"container mt-5\">\n    <h2 class=\"fs-5 mb-4\">نمونه کد در زبان‌های مختلف</h2>\n  </div>\n  <section class=\"container mt-5 codeContainer\">\n    <h3 class=\"fs-6 text-white\">JavaScript</h3>\n    <div class=\"code-box\">\n      <button class=\"copy-btn\" onclick=\"copyCode(this)\">کپی</button>\n      <pre>fetch('https://api.alanchand.com?type=crypto&amp;symbols=btc,eth', {\n  headers: {\n    'Authorization': 'Bearer YOUR_API_TOKEN'\n  }\n})\n.then(res =&gt; res.json())\n.then(data =&gt; console.log(data));\n      </pre>\n    </div>\n\n    <h3 class=\"fs-6 text-white\">PHP</h3>\n    <div class=\"code-box\">\n      <button class=\"copy-btn\" onclick=\"copyCode(this)\">کپی</button>\n      <pre>$curl = curl_init();\ncurl_setopt_array($curl, [\n  CURLOPT_URL =&gt; \"https://api.alanchand.com?type=gold&amp;symbols=sekkeh\",\n  CURLOPT_RETURNTRANSFER =&gt; true,\n  CURLOPT_HTTPHEADER =&gt; [\n    \"Authorization: Bearer YOUR_API_TOKEN\"\n  ],\n]);\n$response = curl_exec($curl);\ncurl_close($curl);\necho $response;\n      </pre>\n    </div>\n\n    <h3 class=\"fs-6 text-white\">Python</h3>\n    <div class=\"code-box\">\n      <button class=\"copy-btn\" onclick=\"copyCode(this)\">کپی</button>\n      <pre>import requests\nheaders = {'Authorization': 'Bearer YOUR_API_TOKEN'}\nres = requests.get('https://api.alanchand.com?type=currency&amp;symbols=usd', headers=headers)\nprint(res.json())\n      </pre>\n    </div>\n\n    <h3 class=\"fs-6 text-white\">C#</h3>\n    <div class=\"code-box\">\n      <button class=\"copy-btn\" onclick=\"copyCode(this)\">کپی</button>\n      <pre>var client = new HttpClient();\nclient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue(\"Bearer\", \"YOUR_API_TOKEN\");\nvar response = await client.GetAsync(\"https://api.alanchand.com?type=crypto&amp;symbols=btc\");\nConsole.WriteLine(await response.Content.ReadAsStringAsync());\n      </pre>\n    </div>\n  </section>\n\n  <div>\n                  <!-- faq -->\n        <section class=\"container mt-4\">\n            <div class=\"card p-3\">\n                <section class=\"my-4\">\n                    <h2 class=\"my-3 text-primary text-center fw-bold fs-5\">سوالات متداول</h2>\n                    <div class=\"faqAccordion\">\n                                                    <div class=\"faqItem\">\n                                <button class=\"faqQuestion\" aria-expanded=\"false\" aria-controls=\"faq0\" id=\"btn0\">\n                                    هزینه استفاده از API چقدر است؟                                </button>\n                                <div class=\"faqAnswerWrapper\" id=\"faq0\" hidden=\"\">\n                                    <div class=\"faqAnswer\">\n                                        <div>دو پلن برای استفاده از API وجود دارد: پلن ۶ ماهه با هزینه ۶۵ تتر و پلن یک‌ساله با هزینه ۱۰۰ تتر.</div>\n                                    </div>\n                                </div>\n                            </div>\n                                                    <div class=\"faqItem\">\n                                <button class=\"faqQuestion\" aria-expanded=\"false\" aria-controls=\"faq1\" id=\"btn1\">\n                                    آیا امکان تست API وجود دارد؟                                </button>\n                                <div class=\"faqAnswerWrapper\" id=\"faq1\" hidden=\"\">\n                                    <div class=\"faqAnswer\">\n                                        <div>بله، از طریق <a href=\"https://t.me/alanchand_token_bot\">ربات تلگرامی</a> که لینک آن در همین صفحه قرار دارد می‌توانید به‌صورت خودکار یک توکن رایگان ۳ روزه برای تست دریافت کنید.</div>\n                                    </div>\n                                </div>\n                            </div>\n                                                    <div class=\"faqItem\">\n                                <button class=\"faqQuestion\" aria-expanded=\"false\" aria-controls=\"faq2\" id=\"btn2\">\n                                    آیا استفاده از API محدودیت دارد؟                                </button>\n                                <div class=\"faqAnswerWrapper\" id=\"faq2\" hidden=\"\">\n                                    <div class=\"faqAnswer\">\n                                        <div>بله، حداکثر ۱۵۰۰ درخواست در روز و ۵۰۰۰۰ درخواست در ماه مجاز است.</div>\n                                    </div>\n                                </div>\n                            </div>\n                                                    <div class=\"faqItem\">\n                                <button class=\"faqQuestion\" aria-expanded=\"false\" aria-controls=\"faq3\" id=\"btn3\">\n                                    آیا امکان استفاده از WebSocket وجود دارد؟                                </button>\n                                <div class=\"faqAnswerWrapper\" id=\"faq3\" hidden=\"\">\n                                    <div class=\"faqAnswer\">\n                                        <div>متأسفانه خیر، در حال حاضر تنها دسترسی از طریق API REST فراهم است.</div>\n                                    </div>\n                                </div>\n                            </div>\n                                                    <div class=\"faqItem\">\n                                <button class=\"faqQuestion\" aria-expanded=\"false\" aria-controls=\"faq4\" id=\"btn4\">\n                                    اگر از API راضی نبودیم آیا امکان بازگشت وجه وجود دارد؟                                </button>\n                                <div class=\"faqAnswerWrapper\" id=\"faq4\" hidden=\"\">\n                                    <div class=\"faqAnswer\">\n                                        <div>در صورتی که مشکل از سمت ما باشد (مانند کندی، اختلال، یا به‌روزرسانی‌نشدن قیمت‌ها)، بازگشت وجه در هر زمان امکان‌پذیر است. در غیر این صورت، تنها تا ۷ روز پس از خرید می‌توانید از طریق پشتیبانی درخواست بازگشت وجه ثبت کنید.</div>\n                                    </div>\n                                </div>\n                            </div>\n                                            </div>\n                </section>\n            </div>\n        </section>\n      </div>\n\n  <script>\n    function copyCode(btn) {\n      const code = btn.nextElementSibling.innerText;\n      const textarea = document.createElement(\"textarea\");\n      textarea.value = code;\n      document.body.appendChild(textarea);\n      textarea.select();\n      document.execCommand(\"copy\");\n      document.body.removeChild(textarea);\n      btn.innerText = \"کپی شد!\";\n      setTimeout(() => btn.innerText = \"کپی\", 1500);\n    }\n  </script>\n</main>\n<div class=\"container footer\" style=\"margin-bottom: 5em;\">\n  <!-- alanFooter -->\n  <div class=\"row\">\n    <div class=\"col-12 mb-4\">\n      <div class=\"card p-3 text-dark\">\n        <p>\n          الان چند سامانه‌ای است که قیمت دلار، یورو و ارزهای دیگر، طلا، سکه و ارزهای دیجیتال مختلف را از منابع و صرافی‌های مختلف جمع‌آوری کرده و بدون تغییر، جهت‌گیری و با جهت‌دهی در رسانه‌های مختلف خود منتشر می‌کند. <strong>قیمت‌ها به هیچ عنوان دستوری نیست و نخواهد شد.</strong><br>سعی خواهد شد قیمت‌ها همیشه دقیق و مطابق بازار باشد و به صورت منظم آپدیت شود.        </p>\n      </div>\n    </div>\n    <div class=\"col-md-3\">\n      <div class=\"footerDarkBox\">\n        <div class=\"d-flex logoTxt\">\n          <img src=\"/assets/img/logo/alanchandLogo.svg\" alt=\"الان چند؟! نرخ لحظه ای ارز، طلا، سکه و کریپتو\">\n          <div class=\"d-flex flex-column\">\n            <div class=\"fs-5 fw-bolder me-1 text-white\">\n              الان چند؟            </div>\n            <div class=\"fs-7 fw-light text-white\">\n              نرخ لحظه‌ای ارز،‌ طلا و سکه            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"col-md-9\">\n      <div class=\"footerBoxLight\">\n        <div class=\"row\">\n          <div class=\"col-md-3\">\n            <ul>\n              <li><a href=\"/media/telegram-bot\">\n                  ربات تلگرام                </a></li>\n              <li><a href=\"/media/api\">\n                  توسعه دهندگان                </a></li>\n            </ul>\n          </div>\n          <div class=\"col-md-3\">\n            <ul>\n              <li><a href=\"https://t.me/alanchandcom\">\n                  کانال تلگرام                </a></li>\n              <li><a href=\"https://www.instagram.com/alanchandcom\">\n                  اینستاگرام                </a></li>\n            </ul>\n          </div>\n          <div class=\"col-md-6\">\n            <div class=\"d-flex\">\n              <a href=\"https://apps.apple.com/app/alanchand-%D8%A7%D9%84%D8%A7%D9%86-%DA%86%D9%86%D8%AF/id6446062175\">\n                <img src=\"/assets/img/appStoreBtn.jpg\" alt=\"دانلود اپلیکیشن الان چند از اپ استور\" class=\"w-100 rounded\">\n\n              </a>\n              <a href=\"https://play.google.com/store/apps/details?id=com.alanchand.com\" class=\"ms-3\">\n                <img src=\"/assets/img/googlePlayBtn.jpg\" alt=\"دانلود اپلیکیشن الان چند از گوگل پلی\" class=\"w-100 rounded\">\n\n              </a>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n<script src=\"/assets/js/scripts_v6.js\"></script>\n<script defer=\"\" src=\"https://static.cloudflareinsights.com/beacon.min.js/v8c78df7c7c0f484497ecbca7046644da1771523124516\" integrity=\"sha512-8DS7rgIrAmghBFwoOTujcf6D9rXvH8xm8JQ1Ja01h9QX8EzXldiszufYa4IFfKdLUKTTrnSFXLDkUEOTrZQ8Qg==\" data-cf-beacon=\"{&quot;version&quot;:&quot;2024.11.0&quot;,&quot;token&quot;:&quot;de46c6814ec8428bb13f94eb1e0ccb24&quot;,&quot;r&quot;:1,&quot;server_timing&quot;:{&quot;name&quot;:{&quot;cfCacheStatus&quot;:true,&quot;cfEdge&quot;:true,&quot;cfExtPri&quot;:true,&quot;cfL4&quot;:true,&quot;cfOrigin&quot;:true,&quot;cfSpeedBrain&quot;:true},&quot;location_startswith&quot;:null}}\" crossorigin=\"anonymous\"></script>\n\n</body></html>",
