generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  phone         String   @unique
  email         String?  @unique
  password      String?
  fullName      String?  @default("")
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  isFrozen      Boolean  @default(false)
  role          String   @default("user")
  avatar        String?
  referredBy    String?
  referralCode  String   @unique
  userLevel     String   @default("bronze")
  levelUpgradedAt DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile             Profile?
  wallet              Wallet?
  goldWallet          GoldWallet?
  kyc                 KYCRequest?
  transactions        Transaction[]
  referrals           Referral[]       @relation("Referrer")
  referredByRel       Referral[]       @relation("Referred")
  notifications       Notification[]
  tickets             SupportTicket[]
  otpCodes            OTPCode[]
  sessions            UserSession[]
  priceAlerts         PriceAlert[]
  goldLoans           GoldLoan[]
  gamification        UserGamification?
  achievements        UserAchievement[]
  savingGoals         SavingGoal[]
  autoBuyPlans        AutoBuyPlan[]
  checkIns            CheckIn[]
  pricePredictions    PricePrediction[]
  sentGifts           GiftTransfer[]   @relation("GiftSender")
  receivedGifts       GiftTransfer[]   @relation("GiftReceiver")
  familyMemberships   FamilyWalletMember[]
  vipSubscription     VIPSubscription?
  cashbackRewards     CashbackReward[]
  socialPosts         SocialPost[]
  creatorProfile      CreatorProfile?
  creatorSubmissions  CreatorSubmission[]
  creatorRewards      CreatorReward[]
  goldCard            GoldCard?
  goldCardTx          GoldCardTransaction[]
  payments            Payment[]
  merchant            Merchant?
  blogPosts           BlogPost[]
  telegramUser        TelegramUser?
  activities          UserActivity[]
  roles               UserRole[]
  insuranceOrders     InsuranceOrder[]
  cars               UserCar[]
  carServiceOrders   CarServiceOrder[]
  utilityPayments    UtilityPayment[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  permissions String   @default("[]")
  color       String   @default("#6B7280")
  isSystem    Boolean  @default(false)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          UserRole[]
  rolePermissions RolePermission[]
}

model UserRole {
  id          String   @id @default(cuid())
  userId      String
  roleId      String
  assignedBy  String?
  assignedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  module      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  nationalId  String?
  birthDate   String?
  iban        String?
  bankCard    String?
  province    String?
  city        String?
  address     String?
  postalCode  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KYCRequest {
  id            String   @id @default(cuid())
  userId        String   @unique
  idCardImage     String?
  idCardBackImage String?
  selfieImage     String?
  bankCardImage    String?
  verificationVideo String?
  status        String   @default("pending")
  adminNote     String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Float    @default(0)
  frozenBalance Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoldWallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  goldGrams   Float    @default(0)
  frozenGold  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoldPrice {
  id          String   @id @default(cuid())
  buyPrice    Float
  sellPrice   Float
  marketPrice Float
  ouncePrice  Float
  spread      Float    @default(0)
  currency    String   @default("IRR")
  isManual    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  type           String
  amountFiat     Float    @default(0)
  amountGold     Float    @default(0)
  fee            Float    @default(0)
  goldPrice      Float?
  status         String   @default("pending")
  referenceId    String   @unique
  description    String?
  toUserId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique
  rewardType   String   @default("cash")
  rewardAmount Float    @default(0)
  status       String   @default("pending")
  claimedAt    DateTime?
  createdAt    DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  body        String
  type        String   @default("info")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id          String    @id @default(cuid())
  userId      String
  subject     String
  category    String    @default("general")
  status      String    @default("open")
  priority    String    @default("normal")
  department  String    @default("support")
  assignedTo  String?
  rating      Int?
  feedback    String?
  slaDeadline DateTime?
  closedAt    DateTime?
  firstReplyAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String
  content     String
  isAdmin     Boolean  @default(false)
  isInternal  Boolean  @default(false)
  attachments String   @default("[]")
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model OTPCode {
  id          String   @id @default(cuid())
  userId      String?
  phone       String
  code        String
  purpose     String   @default("login")
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  expiresAt   DateTime
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String?
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceHistory {
  id          String   @id @default(cuid())
  price       Float
  interval    String   @default("1h")
  openPrice   Float
  highPrice   Float
  lowPrice    Float
  closePrice  Float
  volume      Float    @default(0)
  timestamp   DateTime @default(now())
}

model CMSPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String
  seoTitle    String?
  seoDesc     String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  components  CMSComponent[]
}

model CMSComponent {
  id        String   @id @default(cuid())
  pageId    String
  type      String
  order     Int
  props     String
  page      CMSPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model SmsConfig {
  id          String   @id @default(cuid())
  provider    String   @default("kavenegar")
  apiKey      String   @default("")
  senderNumber String  @default("")
  otpTemplate String   @default("")
  lastTestAt  DateTime?
  lastTestOk  Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

/* ── Security Shield Models ── */

model SecurityEvent {
  id          String   @id @default(cuid())
  type        String   // auth_success, auth_failure, account_frozen, suspicious_activity, bot_detected, rate_limit_exceeded, api_abuse, permission_denied, session_revoked, security_scan
  severity    String   @default("info") // info, warning, critical
  userId      String?
  phone       String?
  ip          String?
  userAgent   String?
  url         String?
  method      String?
  details     String?  // JSON
  riskScore   Int      @default(0)
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model BlockedIP {
  id          String   @id @default(cuid())
  ip          String   @unique
  reason      String?
  blockedBy   String?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SecurityConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id          String   @id @default(cuid())
  group       String
  key         String
  value       String   @default("")
  type        String   @default("text") // text, textarea, boolean, number, json, color, image
  label       String   @default("")
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([group, key])
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  type        String
  condition   String
  targetPrice Int
  isActive    Boolean  @default(true)
  isTriggered Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoldLoan {
  id              String   @id @default(cuid())
  userId          String
  amountRequested Float
  goldCollateral  Float
  goldPriceAtLoan Float
  ltvRatio        Float    @default(0.7)
  interestRate    Float    @default(0.05)
  durationDays    Int      @default(30)
  amountApproved  Float?
  status          String   @default("pending")
  adminNote       String?
  reviewedBy      String?
  reviewedAt      DateTime?
  approvedAt      DateTime?
  dueDate         DateTime?
  repaidAmount    Float    @default(0)
  penaltyAmount   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  repayments  LoanRepayment[]
}

model LoanRepayment {
  id          String   @id @default(cuid())
  loanId      String
  amount      Float
  penalty     Float    @default(0)
  method      String   @default("wallet")
  status      String   @default("completed")
  description String?
  createdAt   DateTime @default(now())

  loan GoldLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
}

model LoanSetting {
  id             String   @id @default(cuid())
  key            String   @unique
  value          String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/* ── Blog Module ── */

model BlogCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#D4AF37")
  icon        String   @default("BookOpen")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts BlogPost[]
}

model BlogTag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPostTag[]
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String   @default("")
  excerpt       String   @default("")
  featuredImage String?
  status        String   @default("draft") // draft, published, archived
  seoTitle      String?
  seoDesc       String?
  readTime      Int      @default(1)
  isFeatured    Boolean  @default(false)
  viewCount     Int      @default(0)
  publishedAt   DateTime?
  authorId      String
  categoryId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category BlogCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags     BlogPostTag[]
}

model BlogPostTag {
  postId String
  tagId  String

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

/* ── Media Library ── */

model Media {
  id        String   @id @default(cuid())
  filename  String
  originalName String
  mimeType  String
  size      Int      @default(0)
  url       String
  alt       String?
  folder    String   @default("general")
  width     Int?
  height    Int?
  uploadedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


/* ═══════════════════════════════════════════════════════════════════════════ */
/*  Gold Payment Gateway Platform — Merchant Ecosystem                   */
/* ═══════════════════════════════════════════════════════════════════════════ */

model Merchant {
  id              String   @id @default(cuid())
  userId          String   @unique
  businessName    String
  businessType    String   @default("online")
  website         String?
  logo            String?
  description     String?
  iban            String?
  settlementType  String   @default("toman")
  settlementFreq  String   @default("daily")
  feeRate         Float    @default(0.01)
  minFee          Float    @default(0)
  maxFee          Float    @default(500000)
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  kycStatus       String   @default("pending")
  totalSales      Float    @default(0)
  totalSalesGold  Float    @default(0)
  totalSettled    Float    @default(0)
  totalSettledGold Float   @default(0)
  pendingSettle   Float    @default(0)
  pendingSettleGold Float  @default(0)
  riskScore       Float    @default(0)
  webhookUrl      String?
  webhookSecret   String?
  brandingColor   String   @default("#D4AF37")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeys         ApiKey[]
  payments        GatewayPayment[]
  refunds         GatewayRefund[]
  settlements     Settlement[]
  webhooksLogs    WebhookLog[]
  invoices        Invoice[]
  qrCodes         QrCode[]
}

model ApiKey {
  id        String   @id @default(cuid())
  merchantId String
  keyHash   String   @unique
  keyPrefix String
  keyType   String   @default("live")
  name      String   @default("Default Key")
  isActive  Boolean  @default(true)
  lastUsedAt DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model GatewayPayment {
  id             String   @id @default(cuid())
  authority      String   @unique
  merchantId     String
  userId         String?
  amountToman    Float
  amountGold     Float    @default(0)
  goldGrams      Float    @default(0)
  feeToman       Float    @default(0)
  feeGold        Float    @default(0)
  paymentMethod  String   @default("toman")
  status         String   @default("pending")
  refId          String?
  description    String?
  callbackUrl    String?
  customerPhone  String?
  customerEmail  String?
  customerName   String?
  cardPan        String?
  goldPriceAtPay Float?
  metadata       String   @default("{}")
  paidAt         DateTime?
  verifiedAt     DateTime?
  settledAt      DateTime?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  merchant   Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  refunds    GatewayRefund[]
  webhookLogs WebhookLog[]
}

model GatewayRefund {
  id           String   @id @default(cuid())
  paymentId    String
  merchantId   String
  amountToman  Float    @default(0)
  amountGold   Float    @default(0)
  reason       String   @default("")
  status       String   @default("pending")
  refundMethod String   @default("original")
  processedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payment GatewayPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  merchant Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Settlement {
  id              String   @id @default(cuid())
  merchantId      String
  amountToman     Float
  amountGold      Float    @default(0)
  feeToman        Float    @default(0)
  type            String   @default("auto")
  periodStart     DateTime
  periodEnd       DateTime
  status          String   @default("pending")
  iban            String?
  transactionRef  String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model WebhookLog {
  id          String   @id @default(cuid())
  paymentId   String
  merchantId  String
  url         String
  method      String   @default("POST")
  payload     String
  response    String?
  statusCode  Int      @default(0)
  success     Boolean  @default(false)
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  payment GatewayPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  merchant Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String   @id @default(cuid())
  merchantId     String
  invoiceNumber  String   @unique
  customerName   String
  customerPhone  String?
  customerEmail  String?
  items          String   @default("[]")
  amountToman    Float
  amountGold     Float    @default(0)
  taxToman       Float    @default(0)
  discountToman  Float    @default(0)
  totalToman     Float
  totalGold      Float    @default(0)
  status         String   @default("pending")
  dueDate        DateTime?
  paidAt         DateTime?
  paymentId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}



model QrCode {
  id          String   @id @default(cuid())
  merchantId  String
  title       String
  amountToman Float
  amountGold  Float    @default(0)
  isFixed     Boolean  @default(false)
  isActive    Boolean  @default(true)
  scanCount   Int      @default(0)
  token       String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model RiskEvent {
  id          String   @id @default(cuid())
  paymentId   String?
  userId      String?
  merchantId  String?
  eventType   String
  riskScore   Float
  details     String?
  isResolved  Boolean  @default(false)
  resolveNote String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


/* ═══════════════════════════════════════════════════════════════════════════ */
/*  NEW MODULES — Advanced Gold Platform Features                          */
/* ═══════════════════════════════════════════════════════════════════════════ */

/* ── Achievement / Gamification Module ── */

model UserGamification {
  id              String   @id @default(cuid())
  userId          String   @unique
  xp              Int      @default(0)
  level           Int      @default(1)
  totalBadges     Int      @default(0)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastCheckInAt   DateTime?
  checkInCount    Int      @default(0)
  predictionScore Int      @default(0)
  referralCount   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  icon        String   @default("trophy")
  category    String   @default("general")
  xpReward    Int      @default(0)
  goldRewardMg Float   @default(0)
  sortOrder   Int      @default(0)
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())

  earnedBy    UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

/* ── Saving Goal Module ── */

model SavingGoal {
  id                 String   @id @default(cuid())
  userId             String
  title              String
  description        String?
  icon               String   @default("target")
  targetAmountFiat   Float
  targetGrams        Float
  currentGrams       Float    @default(0)
  currentAmountFiat  Float    @default(0)
  monthlyContribution Float   @default(0)
  deadline           DateTime?
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/* ── Auto Buy Plan Module ── */

model AutoBuyPlan {
  id              String   @id @default(cuid())
  userId          String
  amountFiat      Float
  frequency       String   @default("monthly")
  dayOfMonth      Int      @default(1)
  isActive        Boolean  @default(true)
  lastExecutedAt  DateTime?
  nextExecuteAt   DateTime?
  totalExecutions Int      @default(0)
  totalSpent      Float    @default(0)
  totalGoldBought Float    @default(0)
  failedCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/* ── Daily Check-In Module ── */

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  dayNumber Int
  rewardType  String   @default("fiat")
  rewardValue Float    @default(0)
  xpEarned  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

